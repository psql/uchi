# うち — copy this to .env and fill in your values

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your-token-here

# Comma-separated Telegram user IDs or usernames allowed to control the house
# Leave empty to allow anyone who messages the bot
ALLOWED_USERS=

# Ollama settings (default: local llama3.2)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# VibeDJ web panel port
VIBEDJ_PORT=6969
